#!/bin/bash

# addproject - Add a directory to Project Launcher app
# Usage:
#   addproject           - adds current directory
#   addproject /path     - adds the specified path

CONFIG_DIR="$HOME/.project_launcher"
CONFIG_FILE="$CONFIG_DIR/projects.json"

# Get directory - use argument if provided, otherwise current directory
if [ -n "$1" ]; then
    # Resolve to absolute path
    if [[ "$1" = /* ]]; then
        TARGET_DIR="$1"
    else
        TARGET_DIR="$(cd "$1" 2>/dev/null && pwd)"
        if [ -z "$TARGET_DIR" ]; then
            echo "Error: Directory does not exist: $1"
            exit 1
        fi
    fi
else
    TARGET_DIR=$(pwd)
fi

# Verify directory exists
if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Directory does not exist: $TARGET_DIR"
    exit 1
fi

PROJECT_NAME=$(basename "$TARGET_DIR")
ADDED_AT=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

# Ensure config directory exists
mkdir -p "$CONFIG_DIR"

# Create empty JSON array if file doesn't exist
if [ ! -f "$CONFIG_FILE" ]; then
    echo "[]" > "$CONFIG_FILE"
fi

# Read existing projects and add new one
# Using Python for reliable JSON manipulation (available on macOS by default)
python3 << EOF
import json
import os

config_file = "$CONFIG_FILE"
target_dir = "$TARGET_DIR"
project_name = "$PROJECT_NAME"
added_at = "$ADDED_AT"

# Read existing projects
try:
    with open(config_file, 'r') as f:
        projects = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    projects = []

# Check if already exists
for p in projects:
    if p.get('path') == target_dir:
        print(f"Project already exists: {project_name}")
        print(f"  Path: {target_dir}")
        exit(0)

# Add new project
new_project = {
    "name": project_name,
    "path": target_dir,
    "addedAt": added_at
}
projects.append(new_project)

# Save back
with open(config_file, 'w') as f:
    json.dump(projects, f, indent=2)

print(f"✓ Added project: {project_name}")
print(f"  Path: {target_dir}")
EOF
