# Copy this file to .env and fill in your values
# NEVER commit .env to git

PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_IS_SANDBOX=true
APPLE_ID=your_apple_id@example.com
TEAM_ID=YOUR_TEAM_ID
APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Backend / Docker ---

# Required
PLAUNCHER_JWT_SECRET=change-me-to-a-random-string
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Optional
PLAUNCHER_CORS_ORIGINS=https://plauncher-super-admin.web.app,https://plauncher-org-admin.web.app
PLAUNCHER_LICENSE_KEY=lic_your_key_here
PLAUNCHER_LICENSE_URL=https://api.plauncher.io
PLAUNCHER_MODE=self-hosted
PLAUNCHER_DB_NAME=plauncher
PORT=8743

# MongoDB connection — use ONE of:
#   Cloud (Atlas): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=YourApp
#   Local Docker:  mongodb://mongo:27017
#   Local dev:     mongodb://localhost:27017
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=ProjectLauncher

# Bootstrap key — set this on first run to create the initial super admin.
# Remove after first login.
# PLAUNCHER_BOOTSTRAP_KEY=your-bootstrap-api-key
