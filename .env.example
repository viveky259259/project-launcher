# Copy this file to .env and fill in your values
# NEVER commit .env to git

PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_IS_SANDBOX=true
APPLE_ID=your_apple_id@example.com
TEAM_ID=YOUR_TEAM_ID
APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Backend / Docker ---

# Required
PLAUNCHER_JWT_SECRET=change-me-to-a-random-string
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Optional
PLAUNCHER_LICENSE_KEY=plk_live_your_key_here
PLAUNCHER_LICENSE_URL=https://api.plauncher.io
PLAUNCHER_MODE=self-hosted
PLAUNCHER_DB_NAME=plauncher
MONGODB_URI=mongodb://mongo:27017
PORT=8743
